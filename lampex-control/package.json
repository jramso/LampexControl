{
  "name": "lampex-control",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler pages dev --proxy http://localhost:5173 --compatibility-date=2024-09-23 --compatibility-flags=nodejs_compat",
    "build": "vue-tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@supabase/postgrest-js": "^1.16.0",
    "vue": "^3.5.39",
    "vue-router": "^4.4.0"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    },
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "openapi-typescript": "^7.3.0",
    "pg": "^8.13.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.107.0"
  }
}
